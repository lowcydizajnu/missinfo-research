# Copy this file to `.env` and fill in the values:  cp .env.example .env
# Never commit your real .env — it is gitignored.

# ── Required ──────────────────────────────────────────────────────────────────

# Secret used to sign admin login tokens. The server refuses to start without it.
# Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Password for the FIRST admin account, which is created automatically the first
# time the server starts (username: admin). It is used ONLY to seed that account
# — after first run, manage accounts and change passwords from inside the panel.
# Choose something strong.
ADMIN_PASSWORD=

# ── Optional ──────────────────────────────────────────────────────────────────

# Enables AI-assisted translation of study content via the Anthropic API.
# The platform is fully functional without it — leave blank to disable.
ANTHROPIC_API_KEY=

# HTTP port (default 3000).
PORT=3000

# SQLite database file path (default ./data/research.db). Auto-created.
DATABASE_PATH=./data/research.db

# Legacy on-disk image fallback path (default ./uploads). Auto-created.
UPLOADS_PATH=./uploads
